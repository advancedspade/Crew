// Prisma schema for Crew — People/HR app
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums

enum CandidateStatus {
  REACHED_OUT
  IN_DIALOGUE
  INTERVIEW
  OFFER
  HIRED
  ARCHIVED
  ON_ICE
}

enum OnboardingStage {
  QUEUE
  THREE_WEEKS
  ONE_WEEK
  STARTED
}

enum OnboardingTicketType {
  DEEL_EMAIL
  OFFICE
  SAFETY
  TRUCK
  IT
  ONE_WEEK
}

enum OnboardingTicketStatus {
  OPEN
  DONE
}

enum FaqStatus {
  PENDING
  PUBLISHED
  ARCHIVED
}

enum CheckinType {
  CHECK_IN
  SALARY_CHANGE
  PROMOTION
  NOTE
}

// Models

model AppUser {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  image              String?
  defaultTicketTypes Json?
  slackUserId        String?
  lastLogin          DateTime  @default(now())
  createdAt          DateTime  @default(now())

  // Tracker fields — copied from Candidate on link, then editable here
  candidateId        String?   @unique
  startDate          DateTime?
  role               String?
  team               String?
  officeLocation     String?
  manager            String?
  salary             Float?
  salaryType         String?
  equityShares       Float?

  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  checkins  Checkin[]

  @@index([email])
  @@index([team])
}

model Recruiter {
  id        String      @id @default(cuid())
  name      String      @unique
  createdAt DateTime    @default(now())

  candidates Candidate[]
}

model Role {
  id             String   @id @default(cuid())
  title          String
  description    String
  team           String
  officeLocation String?
  employmentType String?
  relevantPeople String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  candidates Candidate[]

  @@index([team])
}

model Candidate {
  id                      String           @id @default(cuid())
  name                    String
  role                    String?
  roleId                  String?
  email                   String?
  phone                   String?
  linkedin                String?
  notes                   String?
  status                  CandidateStatus  @default(REACHED_OUT)
  recruiterId             String?
  recruiterEmail          String?
  startDate               DateTime?
  officeLocation          String?
  salary                  Float?
  salaryType              String?
  manager                 String?
  equityShares            Float?
  team                    String?
  employmentType          String?
  conversion              Boolean?
  personalAddress         String?
  offerStatus             String?
  offerDocId              String?
  offerDriveLink          String?
  offerApproverEmail      String?
  onboardingStageOverride OnboardingStage?
  workEmail               String?
  resumeDriveFileId       String?
  resumeFileName          String?
  resumeWebViewLink       String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  recruiter         Recruiter?          @relation(fields: [recruiterId], references: [id], onDelete: SetNull)
  roleRef           Role?               @relation(fields: [roleId], references: [id], onDelete: SetNull)
  feedback          InterviewFeedback[]
  onboardingTasks   OnboardingTask[]
  onboardingTickets OnboardingTicket[]
  appUser           AppUser?

  @@index([status])
  @@index([recruiterId])
  @@index([recruiterEmail])
  @@index([roleId])
}

model InterviewFeedback {
  id                 String   @id @default(cuid())
  candidateId        String
  submittedBy        String
  submittedByName    String?
  submittedByImage   String?
  feedback           String
  technicalFeedback  String?
  behavioralFeedback String?
  overallScore       Int?
  additionalNotes    String?
  prefersVerbal      Boolean  @default(false)
  createdAt          DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([submittedBy])
}


model Referral {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  linkedin        String?
  notes           String?
  submittedBy     String
  submittedByName String?
  createdAt       DateTime @default(now())

  @@index([submittedBy])
}

model OnboardingTask {
  id            String    @id @default(cuid())
  candidateId   String
  taskKey       String
  assigneeEmail String?
  completedAt   DateTime?
  completedBy   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, taskKey])
  @@index([candidateId])
  @@index([assigneeEmail])
}

model OnboardingTicket {
  id            String                 @id @default(cuid())
  candidateId   String
  type          OnboardingTicketType
  status        OnboardingTicketStatus @default(OPEN)
  assigneeEmail String?
  notes         String?
  data          Json?
  dueDate       DateTime?
  createdAt     DateTime               @default(now())
  completedAt   DateTime?
  completedBy   String?

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, type])
  @@index([candidateId])
  @@index([assigneeEmail])
  @@index([type])
  @@index([status])
  @@index([dueDate])
}

model Feedback {
  id              String   @id @default(cuid())
  type            String   // BUG, FEATURE, GENERAL
  message         String
  submittedBy     String?              // email from session (null if unauthenticated)
  submittedByName String?              // display name from session
  createdAt       DateTime @default(now())

  @@index([submittedBy])
  @@index([type])
}

model Faq {
  id              String    @id @default(cuid())
  question        String
  answer          String?
  status          FaqStatus @default(PENDING)
  submittedBy     String?              // email of submitter (null if unauthenticated)
  submittedByName String?              // display name of submitter
  answeredBy      String?              // admin email who answered
  answeredAt      DateTime?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([submittedBy])
}

model Checkin {
  id        String      @id @default(cuid())
  userId    String
  type      CheckinType @default(CHECK_IN)
  loggedBy  String                       // admin email who logged it
  loggedAt  DateTime    @default(now())
  notes     String?
  createdAt DateTime    @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loggedAt])
}
