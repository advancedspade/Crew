# ─── Database (Supabase) ────────────────────────────────────────────────
# Pooled connection for app runtime (port 6543, pgbouncer)
DATABASE_URL=
# Direct connection for migrations (port 5432)
DIRECT_URL=

# ─── NextAuth ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Dev: http://localhost:3002 — Prod: https://<your-vercel-domain>
NEXTAUTH_URL=

# ─── Google OAuth ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Access control ─────────────────────────────────────────────────────
# Comma-separated. Supports domain wildcards: *@aspadeco.com
# Leave blank in local dev to allow any signed-in Google user.
ALLOWED_EMAILS=
# Admins for recruiting pipeline (gates /recruiting and /api/recruiting)
RECRUITING_EMAILS=

# ─── Optional ───────────────────────────────────────────────────────────
# Cron auth for /api/cron/onboarding-tickets — unset in dev to allow calls
CRON_SECRET=
# Public app URL used in Slack notification links
NEXT_PUBLIC_APP_URL=
# Slack notifications — each missing webhook is silently skipped
SLACK_OFFER_WEBHOOK_URL=
SLACK_RECRUITING_WEBHOOK_URL=
# Per-ticket-type webhooks for onboarding (one channel per ticket type)
SLACK_TICKET_DEEL_WEBHOOK_URL=
SLACK_TICKET_OFFICE_WEBHOOK_URL=
SLACK_TICKET_SAFETY_WEBHOOK_URL=
SLACK_TICKET_TRUCK_WEBHOOK_URL=
SLACK_TICKET_IT_WEBHOOK_URL=
SLACK_TICKET_ONE_WEEK_WEBHOOK_URL=
